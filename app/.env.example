# Copy this to .env and fill in the values before running docker-compose.

# ── Security (REQUIRED — change before any production deployment) ────────────
# Must be a long, random string (e.g. openssl rand -hex 32)
SECRET_KEY=change-me-in-production-use-a-long-random-string

# ── Token expiry (minutes) ───────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── File upload limit ────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10

# ── Database (SQLite path inside backend container) ──────────────────────────
# Override to postgresql+psycopg2://user:pass@host/dbname for Postgres
DATABASE_URL=sqlite:////data/bank_analysis.db

# ── Backend URL (used by the Streamlit frontend) ─────────────────────────────
# When running via docker-compose this should be http://backend:8000
# When running locally: http://localhost:8000
BACKEND_URL=http://backend:8000
